# ==============================================================================
# LUNARATLAS SYSTEM ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and configure appropriate values for your deployment.
# ==============================================================================

# --- DATABASE CONFIGURATION ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lunaratlas
DB_USER=postgres
DB_PASSWORD=postgres

# --- BACKEND API SERVER ---
API_HOST=0.0.0.0
API_PORT=8000
DEBUG_MODE=true

# --- SECURITY & CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- DOWNSAMPLING ENGINE DEFAULTS ---
# Default LTTB bucket size scaling proportion
DEFAULT_DOWNSAMPLE_PROPORTION=0.1
# Overlap margin to prevent peak splitting (0.05 = 5%)
DEFAULT_BUCKET_OVERLAP=0.05
# Statically preserve peaks registered in NIST focus table
PRESERVE_NIST_PEAKS=true
